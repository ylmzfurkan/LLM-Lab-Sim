# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/llm_lab

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# Comma-separated allowed CORS origins
API_CORS_ORIGINS=http://localhost:3000

# Set to "false" to allow anonymous access via X-Anonymous-ID header
REQUIRE_AUTH=false

# Required when REQUIRE_AUTH=true (JWT signing secret)
JWT_SECRET=change-me-in-production

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_SIMULATE=60/minute
