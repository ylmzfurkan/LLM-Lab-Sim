# Supabase — Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase JWT Secret — Dashboard → Settings → API → JWT Secret
# Required by the backend to verify Bearer tokens issued by Supabase Auth.
JWT_SECRET=your-jwt-secret

# Database (Supabase Postgres — Dashboard → Settings → Database → Connection string)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxx.supabase.co:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# API
NEXT_PUBLIC_API_URL=http://localhost:8000
API_CORS_ORIGINS=http://localhost:3000

# Demo mode — when "true", frontend falls back to mock data if the API
# is unreachable (useful for local UI development without a running backend).
# Leave unset or set to "false" in production so errors surface honestly.
NEXT_PUBLIC_DEMO_MODE=true
